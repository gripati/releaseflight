# ────────────────────────────────────────────────────────────────────────────
# Deployment mode
# ────────────────────────────────────────────────────────────────────────────
# self_host = default for V1; signup disabled, owner from env, single tenant
# saas      = V2; public signup, Stripe, marketing pages, multi-tenant
DEPLOY_MODE=self_host

# ────────────────────────────────────────────────────────────────────────────
# Database (Postgres 16)
# ────────────────────────────────────────────────────────────────────────────
# DATABASE_URL — the pooled connection used by the app (Prisma data plane).
#   SECURITY: this MUST connect as a NON-superuser, NON-BYPASSRLS role
#   (e.g. `gp_app`, created by `pnpm db:rls`). Postgres superusers and
#   BYPASSRLS roles ignore Row-Level Security, which silently disables tenant
#   isolation. The app refuses to boot in production if this role bypasses RLS
#   (see assertDbRoleRespectsRls in @marquee/db). The bootstrap superuser `gp`
#   should be used ONLY for migrations/admin via DATABASE_URL_ADMIN below.
#   Dev convenience note: create + set the app role once with
#     psql -c "ALTER ROLE gp_app WITH PASSWORD 'gp_app_dev_password';"
#   Production tuning:
#     ?connection_limit=10  — max connections per app instance
#     ?pool_timeout=10      — seconds to wait for a free connection
#     ?connect_timeout=5    — handshake timeout
#     ?sslmode=require      — when behind RDS / Cloud SQL
#   When using PgBouncer (transaction pooling), DATABASE_URL points at
#   PgBouncer (e.g. :6432) and DIRECT_URL bypasses it for migrations.
DATABASE_URL=postgresql://gp_app:gp_app_dev_password@localhost:5432/gamepublisher?schema=public&connection_limit=10&pool_timeout=10
# Direct URL — used by Prisma CLI for `db push` / `db execute` (rls.sql) and to
# bypass PgBouncer. MUST be a PRIVILEGED role (gp): gp_app cannot run DDL,
# CREATE POLICY, or CREATE ROLE. The runtime client never uses this URL.
DIRECT_URL=postgresql://gp:gp_dev_password@localhost:5432/gamepublisher?schema=public
# DATABASE_URL_ADMIN — bypass-RLS connection for migrations, seeds, auth
# bootstrap (membership lookup) and cross-tenant maintenance. Use the `gp`
# superuser or the `gp_migration_admin` BYPASSRLS role here.
#   REQUIRED when DATABASE_URL is a non-bypass role (gp_app): the unscoped
#   Prisma client reads RLS-protected tables WITHOUT a tenant context (e.g.
#   accepting an invitation), so it must bypass RLS — otherwise those reads
#   silently return zero rows. When unset, the app falls back to DATABASE_URL,
#   which is only safe if DATABASE_URL itself bypasses RLS (the insecure
#   single-superuser dev default).
DATABASE_URL_ADMIN=postgresql://gp:gp_dev_password@localhost:5432/gamepublisher?schema=public
# GP_APP_DB_PASSWORD — dev password the seed assigns to the gp_app runtime role
# (self-host only) so a fresh `pnpm db:reset` produces a working RLS-enforced
# system with no manual ALTER ROLE. Must match the password in DATABASE_URL.
# In production, set gp_app's password via your secret manager instead.
GP_APP_DB_PASSWORD=gp_app_dev_password

# ────────────────────────────────────────────────────────────────────────────
# Redis (cache, queue, pub/sub)
# ────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ────────────────────────────────────────────────────────────────────────────
# Object Storage (MinIO local; S3 prod)
# ────────────────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=gamepublisher
S3_ACCESS_KEY_ID=gp_dev_minio
S3_SECRET_ACCESS_KEY=gp_dev_minio_secret
S3_FORCE_PATH_STYLE=true

# ────────────────────────────────────────────────────────────────────────────
# Secret Manager
# filesystem | aws-sm | vault
# ────────────────────────────────────────────────────────────────────────────
SECRET_PROVIDER=filesystem
SECRETS_DIR=./data/secrets
# Master key (KEK) for envelope-encrypting credentials at rest (AES-256-GCM).
# REQUIRED in production (NODE_ENV=production) — the app refuses to start the
# filesystem secret provider without it. Accepts 64-char hex, 32-byte base64,
# or any passphrase. Generate via: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=
STORAGE_DIR=./data/storage
# HMAC key for signed storage-proxy URLs. REQUIRED in production: must be a
# dedicated random value of >=32 chars (an empty/weak/placeholder value makes
# signed URLs forgeable). Generate via: openssl rand -base64 48
STORAGE_SIGNING_SECRET=


# ────────────────────────────────────────────────────────────────────────────
# Session
# ────────────────────────────────────────────────────────────────────────────
# Generate via: openssl rand -base64 48
SESSION_SECRET=change-me-in-production-min-32-chars-required-for-hmac-signing-of-cookies
SESSION_COOKIE_NAME=gp_session
SESSION_TTL_DAYS=7

# Reverse-proxy trust for rate-limit client IP. X-Forwarded-For is spoofable, so
# it is only honoured when this is "1" (set it ONLY if a trusted proxy/LB sits in
# front and rewrites/appends XFF). TRUSTED_PROXY_HOPS = number of trusted proxies
# (default 1) — the real client IP is taken that many entries from the right.
TRUST_PROXY_HEADERS=
TRUSTED_PROXY_HOPS=1

# Optional SSRF allowlist for the ASO research MCP endpoint (comma-separated
# hostnames). When set, only these hosts may be fetched. Loopback (Astro
# Desktop default) is always allowed; cloud-metadata/link-local/private targets
# are always blocked.
ASO_MCP_ALLOWED_HOSTS=

# ────────────────────────────────────────────────────────────────────────────
# Self-host bootstrap (only used when DEPLOY_MODE=self_host on first boot)
# ────────────────────────────────────────────────────────────────────────────
SELF_HOST_OWNER_EMAIL=owner@example.com
SELF_HOST_OWNER_PASSWORD=change-me-after-first-login

# ────────────────────────────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
APP_NAME=GamePublisher
NODE_ENV=development
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────────────────────
# Observability
# ────────────────────────────────────────────────────────────────────────────
# Prometheus scrape endpoint (set to a 32+ char random string to enable).
# Generate via: openssl rand -hex 24
METRICS_BEARER_TOKEN=

# Sentry / external error tracking (optional — empty disables)
# When set, server-side errors via logger.error are also reported.
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_RELEASE=

# OpenTelemetry — set to an OTLP endpoint to enable distributed tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=gp-web

# ────────────────────────────────────────────────────────────────────────────
# Content-Security-Policy extensions
# ────────────────────────────────────────────────────────────────────────────
# Comma- / space-separated origins added to script-src / connect-src / img-src.
# Use ONLY when you intentionally embed third-party widgets (analytics, etc).
CSP_EXTRA_SCRIPT=
CSP_EXTRA_CONNECT=
CSP_EXTRA_IMG=

# ────────────────────────────────────────────────────────────────────────────
# SaaS-only (leave empty in self_host)
# ────────────────────────────────────────────────────────────────────────────
SAAS_SIGNUP_ENABLED=
SAAS_REQUIRE_EMAIL_VERIFICATION=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
SAAS_DEFAULT_TRIAL_DAYS=14

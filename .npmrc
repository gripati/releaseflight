# pnpm config — default symlink-based layout (NOT hoisted).
#
# Why not hoisted: `node-linker=hoisted` breaks workspace package
# resolution in this monorepo — @marquee/ui, @marquee/core etc. stop being
# discoverable by Next.js after install. The isolated default layout
# keeps workspaces working.
#
# Why we don't enable Turbopack by default: known Next 15.5 issue
# https://github.com/vercel/next.js/issues/53476 — Turbopack walks
# node_modules with its Rust file traverser and can't follow pnpm's
# symlink-into-.pnpm/ pattern. Result: "Next.js package not found" panic.
# The fix is on the Next.js side; until it ships, we use webpack-based
# dev or `pnpm fast` (production-mode + auto-rebuild — see scripts/fast-dev.sh).

# Workspace + dev tool packages still hoisted to root for Prisma + sharp
public-hoist-pattern[]=*@prisma/*
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=*@swc/*

# Peer-dep policy
auto-install-peers=true
strict-peer-dependencies=false

# Lockfile policy (CI runs --frozen-lockfile separately)
prefer-frozen-lockfile=false

# OS-wide store for faster cold installs
store-dir=~/.pnpm-store

# Resolution
resolution-mode=highest
progress=true
